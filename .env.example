# Copy this file to .env and fill in your values
# Never commit .env to GitHub

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Mosaic MCP server (Zeus CMS data — visuals + reviews)
# Staging (default, no auth required):
MOSAIC_MCP_URL=https://stg-pdp-mcp.mosaicwellness.in
# Production (set this when the prod MCP URL is available):
# MOSAIC_MCP_URL=https://pdp-mcp.mosaicwellness.in

# Mixpanel
MIXPANEL_PROJECT_ID=your_project_id
MIXPANEL_SERVICE_ACCOUNT_USERNAME=your_service_account_username
MIXPANEL_SERVICE_ACCOUNT_SECRET=your_service_account_secret

# Email (add later)
GMAIL_SENDER=your_sender@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
GMAIL_RECIPIENT=your_recipient@gmail.com
